{
  "name": "pebble-code",
  "version": "0.1.0",
  "description": "Terminal-native AI coding agent",
  "module": "./index.ts",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./index.ts",
    "./cli": "./src/entrypoints/cli.tsx"
  },
  "bin": {
    "pebble": "./dist/pebble.js"
  },
  "scripts": {
    "dev": "bun run src/entrypoints/cli.tsx",
    "build": "bun run scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "start": "bun run dist/pebble.js"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "@zenobius/ink-mouse": "^1.0.3",
    "ink": "^6.8.0",
    "openai": "^6.33.0",
    "react": "^19.2.4",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.3.3",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
